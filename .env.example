# Copy to .env and adjust. Loaded at startup — change values and restart the app.
# Only SECRET_KEY and the DB_* connection are required; everything else is optional
# and shown here with its default. Full reference: docs/setup-and-operations.md

# --- Core ------------------------------------------------------------------
SECRET_KEY=change-me-to-a-long-random-string
# LOG_LEVEL=INFO                       # DEBUG / INFO / WARNING / ERROR

# --- Database (home DB — the app_* metadata lives here) ---------------------
DB_DRIVER=mysql+pymysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=biggy
DB_PASSWORD=biggy
DB_NAME=biggy
# Alternatively a full SQLAlchemy URL (takes precedence over the DB_* parts):
# DATABASE_URL=mysql+pymysql://biggy:biggy@127.0.0.1:3306/biggy

# --- Uploads / display -------------------------------------------------------
# UPLOAD_FOLDER=                       # default: <instance>/uploads
# CURRENCY_SYMBOL=$                    # display symbol for the 'currency' field type
# (max upload size is fixed at 16 MB — see MAX_CONTENT_LENGTH in app/config.py)

# --- Email (trigger emails / report digests; skipped when unset) ------------
# MAIL_SERVER=
# MAIL_PORT=25
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_USE_TLS=false
# MAIL_DEFAULT_SENDER=biggy@localhost
# NOTIFY_WEBHOOK_TIMEOUT=5             # seconds, outbound email/webhook timeout

# --- Inbound webhooks (global defaults; each webhook can override in the UI) -
# WEBHOOK_MAX_BODY_BYTES=65536
# WEBHOOK_RATE_LIMIT=120               # requests per window, 0 = off
# WEBHOOK_RATE_WINDOW=60               # window seconds

# --- Scheduler (triggers / feeds / pulls / report digests / SLA sweeps) ------
# Prefer cron: `flask --app run run-jobs`. The in-process ticker is optional and
# multi-worker-safe (jobs are claimed atomically).
# SCHEDULER_ENABLED=false
# SCHEDULER_TICK_SECONDS=60

# --- SLA engine ---------------------------------------------------------------
# SLA_DEFAULT_WARN_MINUTES=30          # "due soon" threshold when a policy leaves it blank

# --- Impact map (topology view) ----------------------------------------------
# TOPOLOGY_DEFAULT_DEPTH=2
# TOPOLOGY_MAX_DEPTH=4
# TOPOLOGY_MAX_NODES=150

# --- Security: sessions & sign-in --------------------------------------------
# SESSION_COOKIE_SECURE=false          # set true when serving over HTTPS
# SESSION_LIFETIME_MINUTES=0           # 0 = browser-session cookie; >0 = expiring sessions
# LOGIN_RATE_LIMIT=10                  # failed sign-in attempts per window before lockout (0 = off)
# LOGIN_RATE_WINDOW=300                # lockout window, seconds
# REQUIRE_MFA=false                    # force every user to enroll in two-factor

# --- Security: encryption at rest --------------------------------------------
# A urlsafe-base64 Fernet key protecting integration secrets + TOTP seeds.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# When unset, a stable key is derived from SECRET_KEY (rotating either breaks old ciphertext).
# BIGGY_ENCRYPTION_KEY=

# --- Single sign-on (OIDC; enabled once issuer + client id are set) -----------
# OIDC_ISSUER=                         # e.g. https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_SCOPES=openid email profile
# OIDC_REDIRECT_URI=                   # default: derived (<host>/auth/oidc/callback)
# OIDC_USERNAME_CLAIM=email            # claim matched to a Biggy username
# OIDC_PROVISION=link                  # link = existing users only | jit = auto-create
# OIDC_DEFAULT_ROLE=user               # role for jit-created users
# OIDC_BUTTON_LABEL=Sign in with SSO
