# Copy to .env and adjust. Connection is configurable; default = local MariaDB.
SECRET_KEY=change-me-to-a-long-random-string

DB_DRIVER=mysql+pymysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=biggy
DB_PASSWORD=biggy
DB_NAME=biggy

# Alternatively, set a full SQLAlchemy URL (takes precedence over the DB_* vars):
# DATABASE_URL=mysql+pymysql://biggy:biggy@127.0.0.1:3306/biggy
